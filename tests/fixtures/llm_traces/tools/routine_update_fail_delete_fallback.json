{
  "model_name": "test-routine-update-fail-delete-fallback",
  "expects": {
    "tools_used": ["routine_create", "routine_update", "routine_delete"],
    "tool_results_contain": {
      "routine_update": "Cannot update schedule or timezone on a non-cron routine.",
      "routine_delete": "temp-routine"
    },
    "min_responses": 1
  },
  "steps": [
    {
      "response": {
        "type": "tool_calls",
        "tool_calls": [
          {
            "id": "call_rc_fallback",
            "name": "routine_create",
            "arguments": {
              "name": "temp-routine",
              "trigger_type": "manual",
              "prompt": "Temporary routine for fallback test."
            }
          }
        ],
        "input_tokens": 120,
        "output_tokens": 40
      }
    },
    {
      "response": {
        "type": "tool_calls",
        "tool_calls": [
          {
            "id": "call_ru_fallback",
            "name": "routine_update",
            "arguments": {
              "name": "temp-routine",
              "schedule": "0 */10 * * * *"
            }
          }
        ],
        "input_tokens": 200,
        "output_tokens": 30
      }
    },
    {
      "response": {
        "type": "tool_calls",
        "tool_calls": [
          {
            "id": "call_rd_fallback",
            "name": "routine_delete",
            "arguments": {}
          }
        ],
        "input_tokens": 300,
        "output_tokens": 20
      }
    },
    {
      "response": {
        "type": "text",
        "content": "I recovered from the failed update and cleaned up the original routine.",
        "input_tokens": 380,
        "output_tokens": 25
      }
    }
  ]
}
