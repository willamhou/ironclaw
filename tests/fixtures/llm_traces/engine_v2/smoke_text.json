{
  "model_name": "v2-smoke-text",
  "expects": {
    "response_matches": "(?i)(hello|hi|help|assist)",
    "max_tool_calls": 0,
    "min_responses": 1
  },
  "steps": [
    {
      "request_hint": {
        "last_user_message_contains": "Hello"
      },
      "response": {
        "type": "text",
        "content": "Hello! I'm your AI assistant. How can I help you today?",
        "input_tokens": 100,
        "output_tokens": 20
      }
    }
  ]
}
